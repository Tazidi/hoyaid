rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(userDoc())
        && get(userDoc()).data.role == 'admin';
    }

    function isActiveSpecies() {
      return resource.data.isActive == true;
    }

    function isActiveClassification() {
      return resource.data.status == 'active';
    }

    function ownsClassification() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    match /species/{speciesId} {
      allow read: if isActiveSpecies() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /label_map/{modelVersion} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /app_config/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if false;
    }

    match /classifications/{classificationId} {
      allow read: if isActiveClassification() || ownsClassification() || isAdmin();
      allow create, update, delete: if false;

      match /private/{documentId} {
        allow read: if signedIn()
          && (
            isAdmin()
            || get(/databases/$(database)/documents/classifications/$(classificationId)).data.userId == request.auth.uid
          );
        allow write: if false;
      }
    }

    match /classification_archives/{archiveId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /stats/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
